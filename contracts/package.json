{
  "name": "komoe-contracts",
  "version": "1.0.0",
  "description": "Smart contracts KOMOE — BudgetLedger on Polygon Amoy",
  "private": true,
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "test:coverage": "npx hardhat coverage",
    "deploy:local": "npx hardhat run scripts/deploy.ts --network localhost",
    "deploy:amoy": "npx hardhat run scripts/deploy.ts --network amoy",
    "node": "npx hardhat node",
    "verify": "npx hardhat verify"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@types/node": "^20.0.0",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^16.6.1"
  }
}
