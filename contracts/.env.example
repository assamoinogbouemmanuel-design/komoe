# ─── KOMOE Contracts — Variables d'environnement ──────────────────────────────
# Copiez ce fichier en .env et remplissez vos vraies valeurs
# NE JAMAIS versionner .env

# ─── Alchemy (nœud RPC Polygon Amoy) ──────────────────────────────────────────
# Créer un compte sur https://dashboard.alchemy.com/
# → New App → Polygon Amoy → copier la clé API
ALCHEMY_API_KEY=VOTRE_CLE_ALCHEMY_ICI

# ─── Clé privée du wallet déployeur (DGDDL) ────────────────────────────────────
# ⚠️  JAMAIS committer cette clé !
# Générer un wallet de test : npx hardhat generate-wallet (ou MetaMask → Export clé privée)
# Sur Amoy testnet, obtenir des MATIC gratuits : https://faucet.polygon.technology/
DEPLOYER_PRIVATE_KEY=0x_VOTRE_CLE_PRIVEE_ICI

# ─── Polygonscan API (vérification du contrat) ────────────────────────────────
# Créer un compte sur https://polygonscan.com/
# → API Keys → Ajouter une clé
POLYGONSCAN_API_KEY=VOTRE_CLE_POLYGONSCAN_ICI

# ─── Options ──────────────────────────────────────────────────────────────────
# Activer le gas reporter dans les tests
REPORT_GAS=false
