# ─── KOMOE Backend — Variables d'environnement ────────────────────────────────
# Copier ce fichier en .env et remplir vos valeurs.
# NE JAMAIS VERSIONNER .env (il est dans .gitignore)

# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-changeme-in-production-minimum-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de données — PostgreSQL OBLIGATOIRE ─────────────────────────────────
# ⚠️  PostgreSQL est la base de données cible du projet.
# En développement local : installer PostgreSQL et créer la DB "komoe_dev"
#   Windows : https://www.postgresql.org/download/windows/
#   Commandes :
#     createdb komoe_dev
#     createuser komoe_user --password
#     psql -c "GRANT ALL ON DATABASE komoe_dev TO komoe_user;"
#
# Format : postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>
DATABASE_URL=postgresql://komoe_user:VotreMotDePasse@localhost:5432/komoe_dev

# SQLite (dev rapide UNIQUEMENT — NE PAS utiliser pour les tests finaux ou la prod)
# Pour utiliser SQLite temporairement : laisser DATABASE_URL vide ou commenter la ligne ci-dessus

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Blockchain Polygon Amoy ──────────────────────────────────────────────────
# Phase 3 — Créer un compte Alchemy : https://alchemy.com
# → New App → Polygon → Amoy Testnet → copier l'URL HTTPS
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/VOTRE_CLE_ALCHEMY

# Phase 4 — Adresse du contrat après déploiement via Remix IDE
CONTRACT_ADDRESS=0x_ADRESSE_DEPLOYEE_SUR_AMOY

# Phase 3B — Clé privée du wallet MetaMask dédié au dev (JAMAIS le wallet principal)
DEPLOYER_PRIVATE_KEY=0x_CLE_PRIVEE_WALLET_BACKEND_DEV_UNIQUEMENT

# ─── IPFS Pinata ──────────────────────────────────────────────────────────────
# Phase 3D — Créer un compte Pinata : https://pinata.cloud
# → API Keys → Nouvelle clé → activer pinFileToIPFS + pinJSONToIPFS
PINATA_JWT=VOTRE_JWT_PINATA
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs
