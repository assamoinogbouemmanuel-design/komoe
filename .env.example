# ─── KOMOE — Variables d'environnement ────────────────────────────────────────
# Copiez ce fichier en .env.local et remplissez vos vraies valeurs
# NE JAMAIS versionner .env.local

# ─── Réseau Polygon ────────────────────────────────────────────────────────────
# Phase 1 (développement) : Polygon Amoy Testnet (Chain ID : 80002)
# Phase 3 (production)    : Polygon Mainnet (Chain ID : 137)
NEXT_PUBLIC_POLYGON_CHAIN_ID=80002
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/VOTRE_CLE_ALCHEMY

# ─── Smart Contract ────────────────────────────────────────────────────────────
# Adresse déployée après `npx hardhat run scripts/deploy.ts --network amoy`
NEXT_PUBLIC_CONTRACT_ADDRESS=0x...ADRESSE_BUDGETLEDGER_SUR_AMOY

# ─── Explorateur Polygon ───────────────────────────────────────────────────────
# Phase 1 : Amoy testnet
NEXT_PUBLIC_POLYGONSCAN_URL=https://amoy.polygonscan.com
# Phase 3 : Mainnet → https://polygonscan.com

# ─── Alchemy (nœud RPC) ────────────────────────────────────────────────────────
# Créer un compte sur https://dashboard.alchemy.com/
# → New App → Polygon Amoy → copier la clé API
NEXT_PUBLIC_ALCHEMY_API_KEY=VOTRE_CLE_ALCHEMY

# ─── IPFS / Pinata (stockage justificatifs PDF) ────────────────────────────────
# Créer un compte sur https://app.pinata.cloud/
# → API Keys → Nouvelle clé
PINATA_JWT=VOTRE_JWT_PINATA
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ─── API Backend Django (Phase 2 — à venir) ───────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# En production : NEXT_PUBLIC_API_BASE_URL=https://api.komoe.ci

# ─── Feature flags ─────────────────────────────────────────────────────────────
# true = Phase 1 (données mockées JSON), false = API réelle
NEXT_PUBLIC_USE_MOCK_DATA=true
# true = interactions blockchain on-chain activées
NEXT_PUBLIC_ENABLE_BLOCKCHAIN=false
